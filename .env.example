# MySQL Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=cyberx

# LDAP Configuration
LDAP_SERVER=ldap://127.0.0.1:389
LDAP_USER_DN=cn=admin,dc=cyberx,dc=local
LDAP_PASSWORD=your_ldap_password
LDAP_BASE_DN=dc=cyberx,dc=local

# Flask Configuration
FLASK_SECRET_KEY=replace_with_a_secure_random_key

# Admin Users (comma-separated usernames)
ADMIN_USERS=admin

# Email Alerts (optional - leave blank to disable)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL=admin@yourcompany.com
